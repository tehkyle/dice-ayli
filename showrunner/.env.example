PORT=3000
QLAB_HOST=127.0.0.1
QLAB_SEND_PORT=53000
QLAB_RECEIVE_PORT=53001

# Google OAuth2 — set via GitHub Secrets at deploy time
# Create credentials at console.cloud.google.com → APIs & Services → Credentials
# Add http://localhost:3000/api/auth/google/callback as an authorized redirect URI
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Actors and character tracks are configured in config.json, not here.
# Google Sheets spreadsheet and tab are configured via the in-app gear icon (stored in sheets-config.json).
