{
  "name": "showrunner",
  "version": "1.0.31",
  "description": "Cast management and QLab OSC bridge for interactive theatre",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js & vite",
    "build": "vite build",
    "electron": "npm run build && electron .",
    "dist": "npm run build && electron-builder --mac --publish never",
    "dist-dmg": "npm run build && electron-builder --mac dmg --publish never && open dist/",
    "build-local": "npm run build && electron-builder --mac dir --publish never && codesign --force --deep --sign - dist/mac-arm64/Dacha-Dice-AYLI.app && open dist/mac-arm64/Dacha-Dice-AYLI.app",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "express": "^4.19.2",
    "googleapis": "^144.0.0",
    "node-osc": "^9.1.0"
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "electron": "^33.0.0",
    "electron-builder": "^26.8.1",
    "svelte": "^5.55.9",
    "vite": "^8.0.14"
  },
  "build": {
    "appId": "com.ayli.showrunner",
    "productName": "Dacha-Dice-AYLI",
    "afterPack": "./scripts/afterPack.js",
    "asar": false,
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "identity": null
    },
    "dmg": {
      "artifactName": "Dacha-Dice-AYLI-mac.dmg",
      "window": {
        "width": 560,
        "height": 320
      },
      "iconSize": 120,
      "iconTextSize": 14,
      "contents": [
        {
          "x": 150,
          "y": 155,
          "type": "file"
        },
        {
          "x": 410,
          "y": 155,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "files": [
      "**/*",
      "!src/**",
      "!dist/**",
      "!**/*.md",
      "!node_modules/.cache/**",
      "!.git/**"
    ],
    "directories": {
      "output": "dist"
    },
    "publish": {
      "provider": "github",
      "owner": "tehkyle",
      "repo": "dice-ayli"
    }
  }
}
