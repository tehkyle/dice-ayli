{
  "name": "showrunner",
  "version": "1.0.12",
  "description": "Cast management and QLab OSC bridge for interactive theatre",
  "main": "electron-main.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "electron": "electron .",
    "dist": "electron-builder --mac --publish never",
    "build-local": "electron-builder --mac dir --publish never && codesign --force --deep --sign - dist/mac-arm64/Dacha-Dice-AYLI.app && open dist/mac-arm64/Dacha-Dice-AYLI.app",
    "release": "bash scripts/release.sh"
  },
  "dependencies": {
    "alpinejs": "^3.14.0",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "googleapis": "^144.0.0",
    "node-osc": "^9.1.0",
    "socket.io": "^4.7.5"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.ayli.showrunner",
    "productName": "Dacha-Dice-AYLI",
    "asar": false,
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity",
      "identity": null,
      "artifactName": "Dacha-Dice-AYLI-mac.dmg"
    },
    "files": [
      "**/*",
      "!dist/**",
      "!**/*.md",
      "!node_modules/.cache/**",
      "!.git/**"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
